class AdaptadorDrone implements Pato {
    private final Drone drone;

    public AdaptadorDrone(Drone drone) {
        this.drone = drone;
    }

    @Override
    public void cuack() {
     
        drone.beep();
    }

    @Override
    public void vuelo() {
       
        drone.despegar();
        drone.rotar();
    }
}